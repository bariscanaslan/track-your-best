# ============================================
# MACHINE LEARNING MODELS & DATA
# ============================================
# ML Models (Large binary files - use Git LFS or cloud storage)
models_bin/*.pkl
models_bin/*.onnx
models_bin/*.h5
models_bin/*.pt
models_bin/*.pth
models_bin/*.joblib

# EXCEPTION: Keep model metadata
!models_bin/model_meta.json
!models_bin/.gitkeep

# Training Data (Large CSV files)
data/*.csv
data/*.xlsx
data/*.json
data/*.parquet

# EXCEPTION: Keep sample/test data
!data/sample_*.csv
!data/.gitkeep

# Temporary ML files
*.npy
*.npz
checkpoints/
logs/
runs/
tensorboard/

