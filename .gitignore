# ============================================
# MACHINE LEARNING MODELS & DATA
# ============================================
# ML Models (Large binary files - use Git LFS or cloud storage)
TYB.MLService/models_bin/*.pkl
TYB.MLService/models_bin/*.onnx
TYB.MLService/models_bin/*.h5
TYB.MLService/models_bin/*.pt
TYB.MLService/models_bin/*.pth
TYB.MLService/models_bin/*.joblib

# EXCEPTION: Keep model metadata
TYB.MLService/!models_bin/model_meta.json
TYB.MLService/!models_bin/.gitkeep

# Training Data (Large CSV files)
TYB.MLService/data/*.csv
TYB.MLService/data/*.xlsx
TYB.MLService/data/*.json
TYB.MLService/data/*.parquet

# EXCEPTION: Keep sample/test data
!data/sample_*.csv
!data/.gitkeep

# Temporary ML files
*.npy
*.npz
TYB.MLService/checkpoints/
TYB.MLService/logs/
TYB.MLService/runs/
TYB.MLService/tensorboard/

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

