trackyourbest/**/bin/
trackyourbest/**/obj/
trackyourbest/**/.env
trackyourbest/**/.env.*
trackyourbest/**/.venv/
trackyourbest/**/venv/
trackyourbest/**/__pycache__/
trackyourbest/**/*.pyc
trackyourbest/**/*.log
trackyourbest/**/.vs/
trackyourbest/**/.idea/
trackyourbest/**/.vscode/

# OS / editor
.DS_Store
Thumbs.db
*.user
*.suo
*.tmp