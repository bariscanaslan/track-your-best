# her şeyi ignore et
*

# sadece bunları dahil et
!.gitignore
!README.md
!trackyourbest/
!trackyourbest/**

# explicitly ignore unwanted dirs
simulations/
database/
esp32-sim/
mobile-sim/
backend/

models_bin

# trackyourbest altında git'e gitmemesi gerekenler
trackyourbest/**/node_modules/
