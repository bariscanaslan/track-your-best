# TYB MLService - Environment Variables

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/tyb_production

# OSRM (ETA için gerekli!)
OSRM_URL=http://localhost:5000

# Logging
LOG_LEVEL=INFO

# Models
MODELS_DIR=./models_bin

# Job Intervals (seconds)
JOB_ANOMALY_INTERVAL=120
JOB_DRIVER_SCORING_INTERVAL=300
JOB_ETA_PREDICTION_INTERVAL=180  # 3 minutes - live ETA updates
JOB_ROUTE_OPTIMIZATION_INTERVAL=600